@model WorkItemsPageViewModel
@{
    ViewData["Title"] = "Задачи";
}

<div class="page-title">Задачи</div>
<p class="muted mb-3">Здесь можно создавать задачи через UI и через API, а потом проверять БД.</p>

<div class="row g-3">
    <div class="col-12 col-lg-4">
        <div class="form-surface">
            <div class="fw-semibold mb-2">Новая задача</div>
            <form asp-action="Create" method="post" class="stack">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="Create.Title" class="form-label"></label>
                    <input asp-for="Create.Title" class="form-control" />
                    <span asp-validation-for="Create.Title" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="Create.Description" class="form-label"></label>
                    <textarea asp-for="Create.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Create.Description" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary align-self-start">Создать</button>
            </form>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="table-wrap">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Статус</th>
                        <th>Создано</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="small text-muted">@item.Description</div>
                            </td>
                            <td>@item.Status</td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                @if (item.Status != "Done")
                                {
                                    <form asp-action="Complete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-success btn-sm">Готово</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
