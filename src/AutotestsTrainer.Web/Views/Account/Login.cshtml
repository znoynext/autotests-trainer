@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-5">
        <div class="form-surface">
            <div class="page-title">Вход в стенд</div>
            <p class="muted">Используй демо-аккаунт из главной страницы.</p>

            <form asp-action="Login" method="post" class="stack">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary align-self-start" disabled>Войти</button>
            </form>
        </div>
    </div>
</div>
